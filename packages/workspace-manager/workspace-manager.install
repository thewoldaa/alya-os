post_install() {
    /usr/bin/gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
    /usr/bin/update-desktop-database -q 2>/dev/null || true
}

post_upgrade() {
    post_install
}

pre_remove() {
    true
}

post_remove() {
    /usr/bin/gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
    /usr/bin/update-desktop-database -q 2>/dev/null || true
}
