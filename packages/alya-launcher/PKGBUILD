# Maintainer: Alya OS Team <dev@alya-os.org>
pkgname=alya-launcher
pkgver=0.1.0
pkgrel=1
pkgdesc="Alya OS - Lightweight full-screen launcher"
arch=('any')
url="https://alya-os.org"
license=('MIT')
depends=('python' 'python-gobject' 'gtk3' 'python-cairo')
install=alya-launcher.install
source=('launcher.py' 'launcher.json' 'alya-launcher.desktop' 'alya-icon.png' 'LICENSE')
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')
backup=()

package() {
    install -Dm755 "${srcdir}/launcher.py" "${pkgdir}/usr/bin/alya-launcher"
    install -Dm644 "${srcdir}/launcher.json" "${pkgdir}/usr/share/alya/launcher.json"
    install -Dm644 "${srcdir}/alya-launcher.desktop" "${pkgdir}/usr/share/applications/alya-launcher.desktop"
    install -Dm644 "${srcdir}/alya-icon.png" "${pkgdir}/usr/share/pixmaps/alya-launcher.png"
    install -Dm644 "${srcdir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
